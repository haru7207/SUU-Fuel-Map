{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "profilePhotoUrl": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "PilotNote": {
      "title": "Pilot Note",
      "description": "Notes shared by pilots on airports",
      "type": "object",
      "properties": {
        "airportId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorProfilePhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["airportId", "authorId", "authorName", "content", "createdAt"]
    },
    "FuelPrices": {
      "title": "Fuel Prices",
      "description": "Shared dynamic fuel prices map",
      "type": "object",
      "properties": {
        "prices": { "type": "object", "description": "Map of airport ICAOs to their fuel prices" },
        "lastUpdated": { "type": "string", "description": "Timestamp when prices were last refreshed" }
      },
      "required": ["prices", "lastUpdated"]
    },
    "FuelPriceHistory": {
      "title": "Fuel Price History",
      "description": "Historical fuel prices for an airport over time",
      "type": "object",
      "properties": {
        "airportId": { "type": "string" },
        "history": { "type": "array", "description": "List of historical price entries" }
      },
      "required": ["airportId", "history"]
    },
    "AirportWeatherCache": {
      "title": "Airport Weather Cache",
      "description": "Cached METAR and TAF data for an airport",
      "type": "object",
      "properties": {
        "airportId": { "type": "string" },
        "metarData": { "type": "array", "description": "JSON representation of METAR data from AWC" },
        "tafData": { "type": "array", "description": "JSON representation of TAF data from AWC" },
        "lastUpdated": { "type": "string", "description": "ISO timestamp of last successful fetch" }
      },
      "required": ["airportId", "metarData", "tafData", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User data"
    },
    "/pilotNotes/{noteId}": {
      "schema": { "$ref": "#/entities/PilotNote" },
      "description": "Pilot notes collection"
    },
    "/fuelPrices/{docId}": {
      "schema": { "$ref": "#/entities/FuelPrices" },
      "description": "Global fuel prices record"
    },
    "/fuelPriceHistory/{airportId}": {
      "schema": { "$ref": "#/entities/FuelPriceHistory" },
      "description": "A list of historical price data points for an airport"
    },
    "/airportWeatherCache/{airportId}": {
      "schema": { "$ref": "#/entities/AirportWeatherCache" },
      "description": "Cached weather data"
    }
  }
}
